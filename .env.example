APP_NAME=Legacy Vault
ENVIRONMENT=local
DEBUG=true
DATABASE_URL=postgresql+psycopg://eterna:eterna_local_password@localhost:5432/eterna
REDIS_URL=redis://localhost:6379/0

# Generate strong values before running outside local development.
# Fernet key example: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=change-me-use-a-64-character-random-secret
ENCRYPTION_KEY=change-me-generate-a-fernet-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

JWT_ALGORITHM=HS256
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=INFO
MFA_ISSUER=Eterna

# Cloudflare R2 storage. R2 is S3-compatible; keep bucket objects private.
STORAGE_PROVIDER=cloudflare_r2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_R2_PRESIGNED_URL_EXPIRE_SECONDS=900

# Resend transactional/security email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10

# Firebase. Google sign-in needs only the project id (verifies ID tokens).
# FCM push uses the HTTP v1 API: base64-encode the service-account JSON, e.g.
#   base64 -i service-account.json | tr -d '\n'
# FCM_SERVER_KEY is the deprecated legacy key, kept only for back-compat.
FIREBASE_PROJECT_ID=
FCM_SERVICE_ACCOUNT_BASE64=
FCM_SERVER_KEY=

# Paystack (subscriptions / payments). Use sk_test_/pk_test_ keys in development.
# Amounts are charged in PAYSTACK_CURRENCY's minor unit; set plan prices to match.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CURRENCY=NGN
PAYSTACK_CALLBACK_URL=

SENTRY_DSN=

POSTGRES_USER=  
POSTGRES_PASSWORD=
POSTGRES_DB=
